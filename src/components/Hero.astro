---
// Componente Hero.astro
---

<section id="hero-section" class="relative w-full h-[600px] flex items-center overflow-hidden transition-colors duration-500 bg-slate-900">
  
  <div class="absolute inset-0 bg-gradient-to-r from-slate-900 via-slate-900/80 to-transparent z-0"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <div class="max-w-2xl">
      <h1 id="hero-title" class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6 transition-opacity duration-300">
        El Poder de La Tecnología a Favor de su Empresa
      </h1>
      <p id="hero-subtitle" class="text-lg md:text-xl text-cyan-400 mb-8 font-light transition-opacity duration-300">
        Fortalecemos su negocio con las mejores soluciones y productos en Tecnologías de Información
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="#soluciones" class="bg-cyan-400 hover:bg-cyan-300 text-slate-900 font-semibold py-3 px-6 rounded transition-colors duration-300">
          Ver Soluciones
        </a>
        <a href="#contacto" class="bg-transparent border border-white text-white hover:bg-white/10 font-semibold py-3 px-6 rounded transition-colors duration-300">
          Contáctenos
        </a>
      </div>
    </div>
  </div>

  <button id="btn-prev" class="absolute left-4 top-1/2 -translate-y-1/2 z-20 text-white/50 hover:text-white transition-colors cursor-pointer">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-10 h-10">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
    </svg>
  </button>

  <button id="btn-next" class="absolute right-4 top-1/2 -translate-y-1/2 z-20 text-white/50 hover:text-white transition-colors cursor-pointer">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-10 h-10">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
    </svg>
  </button>

  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-20 flex space-x-3">
    <button class="w-3 h-3 rounded-full bg-cyan-400 dot cursor-pointer" data-index="0"></button>
    <button class="w-3 h-3 rounded-full bg-white/50 hover:bg-white dot cursor-pointer" data-index="1"></button>
    <button class="w-3 h-3 rounded-full bg-white/50 hover:bg-white dot cursor-pointer" data-index="2"></button>
  </div>
</section>

<script>
  // Datos de nuestras 3 diapositivas
  const slides = [
    {
      title: "El Poder de La Tecnología a Favor de su Empresa",
      subtitle: "Fortalecemos su negocio con las mejores soluciones y productos en Tecnologías de Información",
      color: "rgb(15 23 42)" // bg-slate-900
    },
    {
      title: "Inteligencia Artificial para el Futuro",
      subtitle: "Automatiza procesos y toma decisiones basadas en datos con nuestros modelos avanzados.",
      color: "rgb(30 27 75)" // indigo-950
    },
    {
      title: "Transformación Digital Segura",
      subtitle: "Protegemos su infraestructura mientras escala hacia la nube con confianza.",
      color: "rgb(2 44 34)" // emerald-950
    }
  ];

  let currentSlide = 0;

  // Seleccionamos los elementos de la pantalla
  const titleEl = document.getElementById('hero-title');
  const subtitleEl = document.getElementById('hero-subtitle');
  const sectionEl = document.getElementById('hero-section');
  const dots = document.querySelectorAll('.dot');

  // Función para cambiar de diapositiva
function updateSlide(index: number) {
    currentSlide = index;

    // Desvanecemos el texto
    if(titleEl) titleEl.style.opacity = '0';
    if(subtitleEl) subtitleEl.style.opacity = '0';

    setTimeout(() => {
      // Cambiamos el texto y el color de fondo
      if(titleEl) titleEl.textContent = slides[index].title;
      if(subtitleEl) subtitleEl.textContent = slides[index].subtitle;
      if(sectionEl) sectionEl.style.backgroundColor = slides[index].color;

      // Volvemos a mostrar el texto
      if(titleEl) titleEl.style.opacity = '1';
      if(subtitleEl) subtitleEl.style.opacity = '1';
    }, 300);

    // Actualizamos el color de los puntitos
    dots.forEach((dot, i) => {
      if (i === index) {
        dot.classList.remove('bg-white/50');
        dot.classList.add('bg-cyan-400');
      } else {
        dot.classList.remove('bg-cyan-400');
        dot.classList.add('bg-white/50');
      }
    });
  }

  // Evento flecha izquierda
  document.getElementById('btn-prev')?.addEventListener('click', () => {
    let prev = currentSlide - 1;
    if (prev < 0) prev = slides.length - 1;
    updateSlide(prev);
  });

  // Evento flecha derecha
  document.getElementById('btn-next')?.addEventListener('click', () => {
    let next = currentSlide + 1;
    if (next >= slides.length) next = 0;
    updateSlide(next);
  });

  // Evento de clic en los puntitos
  dots.forEach(dot => {
    dot.addEventListener('click', (e) => {
      // @ts-ignore
      const index = parseInt(e.target.getAttribute('data-index'));
      updateSlide(index);
    });
  });
</script>